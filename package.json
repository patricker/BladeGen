{
  "name": "bladegen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-schema.mjs",
    "prebuild": "node scripts/sync-schema.mjs && node scripts/build-help-docs.mjs && node scripts/build-help-index.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5173",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "help:build": "node scripts/build-help-docs.mjs && node scripts/build-help-index.mjs",
    "help:lint": "node scripts/lint-help-docs.mjs",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "@playwright/test": "^1.47.2",
    "@types/node": "24.4.0",
    "typescript": "5.9.2",
    "vite": "7.1.5",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "ajv": "^8.12.0",
    "three": "0.180.0",
    "three-mesh-bvh": "^0.7.6",
    "three-bvh-csg": "^0.0.17"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/patricker/BladeGen"
  }
}
